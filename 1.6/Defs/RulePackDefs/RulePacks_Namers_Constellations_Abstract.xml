<Defs>

    <Astralum.Astronomy.Constellations.ConstellationNameRulePackDef>
        <defName>Astra_ConstellationNames_Abstract</defName>
        <categoryId>Abstract</categoryId>
        <rulePackDef>Astra_ConstellationNameRules_Abstract</rulePackDef>
    </Astralum.Astronomy.Constellations.ConstellationNameRulePackDef>

    <RulePackDef>
        <defName>Astra_ConstellationNameRules_Abstract</defName>
        <rulePack>
            <rulesStrings>
                <li>r_name->The [descriptor] [noun]</li>
                <li>r_name->The [title]</li>
                <li>r_name->The [object] of [concept]</li>
                <li>r_name->The [descriptor] [object]</li>
                <li>r_name->[noun] of [concept]</li>
                <li>r_name->The [title]'s [object]</li>
                <li>r_name->The [descriptor] [noun] of [concept]</li>
                <li>r_name->The [noun]</li>
                <li>r_name->The [concept] [object]</li>

                <li>descriptor->Broken</li>
                <li>descriptor->Hidden</li>
                <li>descriptor->Nameless</li>
                <li>descriptor->Veiled</li>
                <li>descriptor->Shifting</li>
                <li>descriptor->Forgotten</li>
                <li>descriptor->Silent</li>
                <li>descriptor->Faded</li>
                <li>descriptor->Endless</li>
                <li>descriptor->Unknown</li>
                <li>descriptor->Distorted</li>
                <li>descriptor->Ancient</li>
                <li>descriptor->Unseen</li>
                <li>descriptor->Hollow</li>

                <li>title->Watcher</li>
                <li>title->Witness</li>
                <li>title->Seeker</li>
                <li>title->Keeper</li>
                <li>title->Dreamer</li>
                <li>title->Bearer</li>
                <li>title->Speaker</li>
                <li>title->Wanderer</li>
                <li>title->Observer</li>
                <li>title->Listener</li>
                <li>title->Shaper</li>
                <li>title->Remnant</li>

                <li>noun->Mark</li>
                <li>noun->Sign</li>
                <li>noun->Glyph</li>
                <li>noun->Omen</li>
                <li>noun->Pattern</li>
                <li>noun->Symbol</li>
                <li>noun->Trace</li>
                <li>noun->Fragment</li>
                <li>noun->Shape</li>
                <li>noun->Echo</li>
                <li>noun->Whisper</li>
                <li>noun->Cipher</li>
                <li>noun->Shade</li>
                <li>noun->Figure</li>
                <li>noun->Rune</li>

                <li>object->Sigil</li>
                <li>object->Seal</li>
                <li>object->Fragment</li>
                <li>object->Echo</li>
                <li>object->Mark</li>
                <li>object->Veil</li>
                <li>object->Mask</li>
                <li>object->Mirror</li>
                <li>object->Trace</li>
                <li>object->Symbol</li>
                <li>object->Shade</li>
                <li>object->Whisper</li>
                <li>object->Rune</li>

                <li>concept->Mystery</li>
                <li>concept->Memory</li>
                <li>concept->Silence</li>
                <li>concept->Dreams</li>
                <li>concept->Meaning</li>
                <li>concept->Echoes</li>
                <li>concept->Absence</li>
                <li>concept->Infinity</li>
                <li>concept->Truth</li>
                <li>concept->Secrets</li>
                <li>concept->Oblivion</li>
                <li>concept->Thought</li>
                <li>concept->Stillness</li>
            </rulesStrings>
        </rulePack>
    </RulePackDef>

