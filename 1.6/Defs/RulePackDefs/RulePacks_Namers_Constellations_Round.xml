<Defs>

    <Astralum.Astronomy.Constellations.ConstellationNameRulePackDef>
        <defName>Astra_ConstellationNames_Round</defName>
        <categoryId>Round</categoryId>
        <rulePackDef>Astra_ConstellationNameRules_Round</rulePackDef>
    </Astralum.Astronomy.Constellations.ConstellationNameRulePackDef>

    <RulePackDef>
        <defName>Astra_ConstellationNameRules_Round</defName>
        <rulePack>
            <rulesStrings>
                <li>r_name->The [descriptor] [noun]</li>
                <li>r_name->The [title]</li>
                <li>r_name->The [object] of [concept]</li>
                <li>r_name->The [descriptor] [object]</li>
                <li>r_name->[noun] of [concept]</li>
                <li>r_name->The [title]'s [object]</li>
                <li>r_name->The [descriptor] [noun] of [concept]</li>
                <li>r_name->The [noun]</li>
                <li>r_name->The [concept] [object]</li>

                <li>descriptor->Polished</li>
                <li>descriptor->Silver</li>
                <li>descriptor->Watching</li>
                <li>descriptor->Full</li>
                <li>descriptor->Silent</li>
                <li>descriptor->Pale</li>
                <li>descriptor->Shining</li>
                <li>descriptor->Ancient</li>
                <li>descriptor->Radiant</li>
                <li>descriptor->Smooth</li>
                <li>descriptor->Still</li>
                <li>descriptor->Golden</li>
                <li>descriptor->Veiled</li>
                <li>descriptor->Luminous</li>
                <li>descriptor->Hidden</li>
                <li>descriptor->Unbroken</li>

                <li>title->Watcher</li>
                <li>title->Observer</li>
                <li>title->Keeper</li>
                <li>title->Wanderer</li>
                <li>title->Sentinel</li>
                <li>title->Witness</li>
                <li>title->Dreamer</li>
                <li>title->Traveler</li>
                <li>title->Guardian</li>
                <li>title->Pilgrim</li>
                <li>title->Seeker</li>
                <li>title->Sleeper</li>

                <li>noun->Orb</li>
                <li>noun->Moon</li>
                <li>noun->Sphere</li>
                <li>noun->Eye</li>
                <li>noun->Pearl</li>
                <li>noun->Halo</li>
                <li>noun->Stone</li>
                <li>noun->Beacon</li>
                <li>noun->Lantern</li>
                <li>noun->Mirror</li>
                <li>noun->Crown</li>
                <li>noun->Disc</li>
                <li>noun->Glow</li>
                <li>noun->Reflection</li>
                <li>noun->Horizon</li>

                <li>object->Orb</li>
                <li>object->Eye</li>
                <li>object->Pearl</li>
                <li>object->Mirror</li>
                <li>object->Lantern</li>
                <li>object->Disc</li>
                <li>object->Halo</li>
                <li>object->Stone</li>
                <li>object->Glow</li>
                <li>object->Reflection</li>
                <li>object->Beacon</li>
                <li>object->Horizon</li>
                <li>object->Crown</li>
                <li>object->Light</li>

                <li>concept->Reflection</li>
                <li>concept->Wholeness</li>
                <li>concept->Stillness</li>
                <li>concept->Moonlight</li>
                <li>concept->Silence</li>
                <li>concept->Dawn</li>
                <li>concept->Night</li>
                <li>concept->Dreams</li>
                <li>concept->Calm Waters</li>
                <li>concept->Harmony</li>
                <li>concept->Heavens</li>
                <li>concept->Radiance</li>
                <li>concept->Twilight</li>
                <li>concept->Eternity</li>
                <li>concept->Memory</li>
                <li>concept->Light</li>
            </rulesStrings>
        </rulePack>
    </RulePackDef>

