                <li>noun->Diagram</li>
                <li>noun->Sequence</li>
                <li>noun->Order</li>

                <li>object->Compass</li>
                <li>object->Scale</li>
                <li>object->Vector</li>
                <li>object->Prism</li>
                <li>object->Grid</li>
                <li>object->Facet</li>
                <li>object->Axis</li>
                <li>object->Lattice</li>
                <li>object->Frame</li>
                <li>object->Measure</li>
                <li>object->Diagram</li>
                <li>object->Pattern</li>
                <li>object->Sequence</li>
                <li>object->Alignment</li>

                <li>concept->Order</li>
                <li>concept->Truth</li>
                <li>concept->Symmetry</li>
                <li>concept->Balance</li>
                <li>concept->Precision</li>
                <li>concept->Logic</li>
                <li>concept->Calculation</li>
