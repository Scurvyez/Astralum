                <li>noun->Lattice</li>
                <li>noun->Axis</li>
                <li>noun->Measure</li>
                <li>noun->Compass</li>
                <li>noun->Grid</li>
                <li>noun->Vector</li>
                <li>noun->Pattern</li>
