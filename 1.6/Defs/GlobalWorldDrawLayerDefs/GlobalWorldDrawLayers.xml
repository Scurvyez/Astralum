<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <GlobalWorldDrawLayerDef>
        <defName>Astra_BackgroundStars</defName>
        <worldDrawLayer>Astralum.Astronomy.BackgroundStars.GlobalDrawLayer_BackgroundStars</worldDrawLayer>
        <modExtensions>
            <li Class="Astralum.Astronomy.BackgroundStars.ModExt_BackgroundStars">
                <starCount>100000</starCount>
                <starSizeRange>0.085~0.85</starSizeRange>
                <galacticPlaneBounds>-0.12~0.12</galacticPlaneBounds>
            </li>
        </modExtensions>
    </GlobalWorldDrawLayerDef>

    <GlobalWorldDrawLayerDef>
        <defName>Astra_Nebulae</defName>
        <worldDrawLayer>Astralum.Astronomy.Nebulae.GlobalDrawLayer_Nebulae</worldDrawLayer>
        <modExtensions>
            <li Class="Astralum.Astronomy.Nebulae.ModExt_Nebulae">
                <nebulaCount>1~100</nebulaCount>
                <nebulaSizeRange>4~12</nebulaSizeRange>
                <galacticPlaneBounds>-0.17~0.17</galacticPlaneBounds>
            </li>
        </modExtensions>
    </GlobalWorldDrawLayerDef>

    <GlobalWorldDrawLayerDef>
        <defName>Astra_Constellations</defName>
        <worldDrawLayer>Astralum.Astronomy.Constellations.GlobalDrawLayer_Constellations</worldDrawLayer>
        <modExtensions>
            <li Class="Astralum.Astronomy.Constellations.ModExt_Constellations">
                <constellationCount>13</constellationCount>
                <maxPlacementAttempts>80</maxPlacementAttempts>
                <baseStarSize>0.25</baseStarSize>
                <brightStarSize>0.85</brightStarSize>
                <constellationSizeMin>3.1</constellationSizeMin>
                <constellationSizeMax>3.5</constellationSizeMax>
                <minViewRotationAngle>160</minViewRotationAngle>
                <maxViewRotationAngle>200</maxViewRotationAngle>
            </li>
        </modExtensions>
    </GlobalWorldDrawLayerDef>

    <GlobalWorldDrawLayerDef>
        <defName>Astra_ConstellationHoverRing</defName>
        <worldDrawLayer>Astralum.Astronomy.Constellations.GlobalDrawLayer_ConstellationHoverRing</worldDrawLayer>
    </GlobalWorldDrawLayerDef>

    <GlobalWorldDrawLayerDef>
        <defName>Astra_ShootingStars</defName>
        <worldDrawLayer>Astralum.Astronomy.ShootingStars.GlobalDrawLayer_ShootingStars</worldDrawLayer>
        <modExtensions>
            <li Class="Astralum.Astronomy.ShootingStars.ModExt_ShootingStars">
                <mTBIntervalSeconds>25</mTBIntervalSeconds>
                <lifetime>0.45~2.875</lifetime>
                <travelDistance>5.0~65.0</travelDistance>
                <length>0.5~2.1</length>
                <width>0.035~0.085</width>
                <galacticPlaneBounds>-0.22~0.22</galacticPlaneBounds>
            </li>
        </modExtensions>
    </GlobalWorldDrawLayerDef>

    <GlobalWorldDrawLayerDef>
        <defName>Astra_SkyCoordinateGrid</defName>
        <worldDrawLayer>Astralum.Astronomy.SkyGrid.GlobalDrawLayer_SkyCoordinateGrid</worldDrawLayer>
    </GlobalWorldDrawLayerDef>

    <GlobalWorldDrawLayerDef>
        <defName>Astra_Pulsars</defName>
        <worldDrawLayer>Astralum.Astronomy.Pulsars.GlobalDrawLayer_Pulsars</worldDrawLayer>
    </GlobalWorldDrawLayerDef>

</Defs>