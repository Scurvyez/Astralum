# =========================================
# Unity
# =========================================

# Ignore everything inside the Unity project
/Astralum/*

# =========================================
# Keep specific Unity folders
# =========================================

!/Astralum/Assets/
!/Astralum/Assets/AssetBundles/
!/Astralum/Assets/AssetBundles.meta

!/Astralum/Assets/Data/
!/Astralum/Assets/Data.meta

!/Astralum/Assets/Editor/
!/Astralum/Assets/Editor.meta

# =========================================
# Keep shader source files
# =========================================

!/Astralum/Assets/**/*.shader
!/Astralum/Assets/**/*.shader.meta

# =========================================
# Ignore generated Unity data
# =========================================

/Astralum/.idea/
/Astralum/Library/
/Astralum/Logs/
/Astralum/Packages/
/Astralum/ProjectSettings/
/Astralum/UserSettings/
/Astralum/obj/
/Astralum/Temp/
/Astralum/Build/
/Astralum/Builds/
/Astralum/Assets/Dev (Unity)/
/Astralum/Assets/Dev (Unity).meta
/Astralum/Assets/Scenes/
/Astralum/Assets/Scenes.meta

# Ignore build artifacts
*.csproj
*.sln
*.user
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Ignore Rider / VS
.idea/
.vs/
*.sln.iml
bin/
obj/
*.user
*.csproj.user
*.suo
*.pdb
*.mdb
*.opendb
*.VC.db

# =========================================
# Keep RimWorld mod folders
# =========================================

!1.6/
!About/
!Textures/

# Ignore built AssetBundles
/1.6/AssetBundles/

# =========================================
# OS junk
# =========================================

.DS_Store
Thumbs.db
desktop.ini