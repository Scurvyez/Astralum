    <Astra_EnableSkyGridToggleLabel>Enable Astralum sky coordinate grid.</Astra_EnableSkyGridToggleLabel>
    <Astra_DisableConstellationLinesToggleLabel>Disable Astralum constellation lines.</Astra_DisableConstellationLinesToggleLabel>
