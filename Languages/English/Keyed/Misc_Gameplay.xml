    <Astra_DisablePulsarInfoToggleLabel>Disable Astralum pulsar hover info.</Astra_DisablePulsarInfoToggleLabel>
    <Astra_EnablePulsarInfoToggleLabel>Enable Astralum pulsar hover info.</Astra_EnablePulsarInfoToggleLabel>
    <Astra_DisableLocalStarInfoToggleLabel>Hide Astralum local star info window.</Astra_DisableLocalStarInfoToggleLabel>
    <Astra_EnableLocalStarInfoToggleLabel>Show Astralum local star info window.</Astra_EnableLocalStarInfoToggleLabel>
    <Astra_DisableCelestialNamingWindowToggleLabel>Hide Astralum celestial naming window.</Astra_DisableCelestialNamingWindowToggleLabel>
