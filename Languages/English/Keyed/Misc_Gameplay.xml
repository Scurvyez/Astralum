    <Astra_UI_CelestialNames_Category>Celestial Names</Astra_UI_CelestialNames_Category>
    <Astra_UI_CelestialNames_SelectionText>Select a celestial object to rename.</Astra_UI_CelestialNames_SelectionText>
    <Astra_UI_CelestialNames_GeneratedName>Generated name:</Astra_UI_CelestialNames_GeneratedName>
    <Astra_UI_CelestialNames_Apply>Apply</Astra_UI_CelestialNames_Apply>
